# --- 1. LLM CONFIGURATION ---
# Set to 'true' to use local Ollama, 'false' for Gemini Cloud
USE_LOCAL_LLM=false
GOOGLE_API_KEY=your_gemini_api_key_here

# Local LLM Settings (Ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=phi3:mini

# --- 2. BACKEND & SECURITY ---
MOCK_SERVER_URL=http://api_server:8000
JWT_ALGORITHM=RS256
# In production, use a persistent private key path instead of generating at lifespan
PRIVATE_KEY_PATH=./backend/certs/private_key.pem

# --- 3. POSTGRES DATABASE ---
DB_USER=postgres
DB_PASSWORD=my_very_secure_password
DB_NAME=iway_db
# Inside Docker, the host is the service name 'postgres_db'
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres_db:5432/${DB_NAME}

# --- 4. QDRANT VECTOR DB ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=iway_knowledge_base

# --- 5. SYSTEM SETTINGS ---
SIMULATE_LATENCY=false
LOG_LEVEL=INFO