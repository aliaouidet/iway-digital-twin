# ===========================================
# I-Way Digital Twin — Environment Variables
# ===========================================

# --- LLM Configuration ---
USE_LOCAL_LLM=false
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3.5:9b

# --- Server Configuration ---
MOCK_SERVER_URL=http://localhost:8000

# --- I-Way Real API (set to true when company provides endpoints) ---
# When true, personal-record lookups (contrat, remboursements, réclamations,
# bénéficiaires) are served by the real I-Way SOAP services below instead of the mock.
IWAY_USE_REAL_API=false
IWAY_API_BASE_URL=http://localhost:8000
IWAY_API_KEY=

# --- I-Way Real API: SOAP / Axis2 web services ---
# Live calls only work on the company LAN. WSDLs are bundled in ./Webservices so the
# SOAP client builds/validates offline; flip IWAY_SOAP_LOAD_LOCAL_WSDL=false on-site to
# fetch the WSDL from the server instead.
IWAY_SOAP_BASE_URL=http://192.168.111.102:8080/axis2/services
IWAY_SOAP_WSDL_DIR=
IWAY_SOAP_LOAD_LOCAL_WSDL=true
IWAY_SOAP_USER=admin
IWAY_SOAP_PASSWORD=admin
IWAY_SOAP_TIMEOUT=15
IWAY_SOAP_CONNECT_TIMEOUT=5

# --- Database ---
DATABASE_URL=postgresql+asyncpg://iway:iway_secret@localhost:5432/iway_db

# --- Redis ---
REDIS_PASSWORD=iway_redis_secret
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@localhost:6379/2

# --- RAG Settings ---
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.70
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# --- HITL Settings ---
CONFIDENCE_THRESHOLD=0.30
HITL_BOOST_FACTOR=1.15
